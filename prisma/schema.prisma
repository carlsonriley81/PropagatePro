generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("owner") // owner, employee
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  plants       Plant[]
  cuttings     Cutting[]
  batches      Batch[]
  tasks        Task[]
  timeLogs     TimeLog[]
  sales        Sale[]
  devices      Device[]
  supplies     Supply[]
  notifications Notification[]
  rootingRules RootingRule[]
  lightSchedules LightSchedule[]
  waterSchedules WaterSchedule[]
}

model Plant {
  id              String   @id @default(uuid())
  name            String
  species         String
  variety         String?
  source          String?
  location        String?
  notes           String?
  imageUrl        String?
  isMotherPlant   Boolean  @default(true)
  quantity        Int      @default(1)
  datePlanted     DateTime @default(now())
  healthStatus    String   @default("healthy")
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])
  cuttings        Cutting[]

  @@index([userId])
  @@index([species])
}

model Cutting {
  id                String   @id @default(uuid())
  uniqueCode        String   @unique @default(uuid())
  plantId           String?
  batchId           String?
  userId            String
  species           String
  variety           String?
  nodeCount         Int      @default(1)
  propagationMethod String   @default("water")
  rootingStatus     String   @default("not_started")
  healthStatus      String   @default("healthy")
  location          String?
  notes             String?
  imageUrl          String?
  dateCut           DateTime @default(now())
  dateRooted        DateTime?
  dateTransplanted  DateTime?
  dateSold          DateTime?
  lastWatered       DateTime?
  costPerCutting    Float    @default(0)
  salePrice         Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id])
  plant             Plant?   @relation(fields: [plantId], references: [id])
  batch             Batch?   @relation(fields: [batchId], references: [id])
  tasks             Task[]
  timeLogs          TimeLog[]
  sale              Sale?

  @@index([userId])
  @@index([species])
  @@index([rootingStatus])
  @@index([healthStatus])
  @@index([batchId])
}

model Batch {
  id          String   @id @default(uuid())
  name        String
  species     String
  userId      String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  cuttings    Cutting[]

  @@index([userId])
}

model Task {
  id          String   @id @default(uuid())
  userId      String
  cuttingId   String?
  taskType    String
  description String?
  duration    Int?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  cutting     Cutting? @relation(fields: [cuttingId], references: [id])

  @@index([userId])
  @@index([taskType])
}

model TimeLog {
  id          String    @id @default(uuid())
  userId      String
  cuttingId   String?
  taskType    String
  startTime   DateTime  @default(now())
  endTime     DateTime?
  duration    Int?
  notes       String?
  isRunning   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  cutting     Cutting?  @relation(fields: [cuttingId], references: [id])

  @@index([userId])
  @@index([isRunning])
}

model Sale {
  id          String   @id @default(uuid())
  cuttingId   String   @unique
  userId      String
  salePrice   Float
  costBasis   Float    @default(0)
  profit      Float    @default(0)
  buyerName   String?
  buyerEmail  String?
  notes       String?
  soldAt      DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cutting     Cutting  @relation(fields: [cuttingId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Supply {
  id          String   @id @default(uuid())
  userId      String
  name        String
  category    String
  quantity    Float    @default(0)
  unit        String?
  costPerUnit Float    @default(0)
  totalCost   Float    @default(0)
  purchasedAt DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([category])
}

model RootingRule {
  id                String @id @default(uuid())
  userId            String
  species           String
  propagationMethod String
  minDays           Int
  maxDays           Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User   @relation(fields: [userId], references: [id])

  @@unique([userId, species, propagationMethod])
  @@index([species])
}

model Device {
  id          String   @id @default(uuid())
  userId      String
  name        String
  deviceType  String
  brand       String?
  zone        String?
  ipAddress   String?
  status      String   @default("offline")
  isOn        Boolean  @default(false)
  lastCommand String?
  lastPing    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  lightSchedules LightSchedule[]
  waterSchedules WaterSchedule[]

  @@index([userId])
  @@index([zone])
}

model LightSchedule {
  id          String   @id @default(uuid())
  userId      String
  deviceId    String
  zone        String?
  onTime      String
  offTime     String
  isActive    Boolean  @default(true)
  mode        String   @default("scheduled")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  device      Device   @relation(fields: [deviceId], references: [id])

  @@index([userId])
  @@index([deviceId])
}

model WaterSchedule {
  id              String   @id @default(uuid())
  userId          String
  deviceId        String?
  zone            String?
  intervalDays    Int      @default(3)
  lastWatered     DateTime?
  nextWatering    DateTime?
  isActive        Boolean  @default(true)
  mode            String   @default("scheduled")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])
  device          Device?  @relation(fields: [deviceId], references: [id])

  @@index([userId])
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  title       String
  message     String
  type        String
  isRead      Boolean  @default(false)
  actionUrl   String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
}
